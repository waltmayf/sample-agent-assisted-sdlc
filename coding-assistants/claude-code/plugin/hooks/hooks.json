{
  "description": "Security hooks for autonomous coding agent",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__gateway__source-control___.*",
        "hooks": [{"type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scope-guard.sh", "timeout": 5}]
      },
      {
        "matcher": "mcp__gateway__project-management___.*",
        "hooks": [{"type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scope-guard.sh", "timeout": 5}]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [{"type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/secret-guard.sh", "timeout": 5}]
      },
      {
        "matcher": "mcp__gateway__source-control___push_files",
        "hooks": [{"type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/secret-guard.sh", "timeout": 5}]
      },
      {
        "matcher": "Bash",
        "hooks": [{"type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/bash-guard.sh", "timeout": 5}]
      },
      {
        "matcher": "mcp__gateway__project-management___add_issue_comment|mcp__gateway__project-management___issue_write|mcp__gateway__source-control___add_pull_request_comment|mcp__gateway__source-control___create_pull_request|mcp__gateway__source-control___push_files",
        "hooks": [{"type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/comment-guard.sh", "timeout": 5}]
      }
    ]
  }
}
