{
  "model": "global.anthropic.claude-opus-4-7",
  "permissionMode": "dontAsk",
  "permissions": {
    "deny": [
      "mcp__gateway__github-code___create_repository",
      "mcp__gateway__github-code___fork_repository",
      "mcp__gateway__github-code___merge_pull_request",
      "mcp__gateway__github-code___pull_request_review_write",
      "mcp__gateway__github-code___update_pull_request_branch",
      "mcp__gateway__github-code___get_me",
      "mcp__gateway__github-code___get_team_members",
      "mcp__gateway__github-code___get_teams",
      "mcp__gateway__github-code___list_repository_collaborators",
      "mcp__gateway__github-code___search_repositories",
      "mcp__gateway__github-code___list_releases",
      "mcp__gateway__github-code___get_latest_release",
      "mcp__gateway__github-code___get_release_by_tag",
      "mcp__gateway__github-code___list_tags",
      "mcp__gateway__github-code___get_tag",
      "mcp__gateway__github-code___search_pull_requests",
      "mcp__gateway__github-code___search_commits",
      "mcp__gateway__github-issues___sub_issue_write",
      "mcp__gateway__github-issues___list_issue_types",
      "mcp__gateway__github-issues___search_issues"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__gateway__github-issues___issue_write",
        "hooks": [{"type": "command", "command": "./hooks/label-governance.sh"}]
      },
      {
        "matcher": "mcp__gateway__github-code___.*",
        "hooks": [{"type": "command", "command": "./hooks/scope-guard.sh"}]
      },
      {
        "matcher": "mcp__gateway__github-issues___.*",
        "hooks": [{"type": "command", "command": "./hooks/scope-guard.sh"}]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [{"type": "command", "command": "./hooks/secret-guard.sh"}]
      },
      {
        "matcher": "mcp__gateway__github-code___push_files",
        "hooks": [{"type": "command", "command": "./hooks/secret-guard.sh"}]
      },
      {
        "matcher": "Bash",
        "hooks": [{"type": "command", "command": "./hooks/bash-guard.sh"}]
      }
    ]
  }
}
